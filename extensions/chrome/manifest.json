{
  "manifest_version": 3,
  "name": "SmartDM Integration",
  "version": "1.0.0",
  "description": "Send files and media to SmartDM.",
  "key": "",
  "permissions": [
    "contextMenus",
    "nativeMessaging",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Download with SmartDM"
  }
}
